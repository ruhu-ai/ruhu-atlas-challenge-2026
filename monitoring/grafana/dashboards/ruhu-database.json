{
  "__inputs": [],
  "annotations": { "list": [] },
  "description": "Ruhu database — query latency, pool saturation, checkout wait.",
  "editable": true,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 1,
      "title": "Query latency",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "s" },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 1 },
      "id": 2,
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(ruhu_db_query_duration_seconds_bucket[5m])) by (le, operation))",
          "legendFormat": "p95 {{operation}}",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.50, sum(rate(ruhu_db_query_duration_seconds_bucket[5m])) by (le, operation))",
          "legendFormat": "p50 {{operation}}",
          "refId": "B"
        }
      ],
      "title": "DB query latency p50 / p95 by operation",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "short" },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 1 },
      "id": 3,
      "targets": [
        {
          "expr": "sum(rate(ruhu_db_query_duration_seconds_count[5m])) by (operation)",
          "legendFormat": "{{operation}}",
          "refId": "A"
        }
      ],
      "title": "DB queries/s by operation",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 9 },
      "id": 4,
      "title": "Connection pool",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "short", "min": 0 },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 10 },
      "id": 5,
      "targets": [
        {
          "expr": "ruhu_db_pool_checked_out",
          "legendFormat": "checked out ({{pool}})",
          "refId": "A"
        },
        {
          "expr": "ruhu_db_pool_overflow",
          "legendFormat": "overflow ({{pool}})",
          "refId": "B"
        }
      ],
      "title": "DB pool connections — checked out and overflow",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "s" },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 10 },
      "id": 6,
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum(rate(ruhu_db_session_checkout_seconds_bucket[5m])) by (le, pool))",
          "legendFormat": "p99 checkout wait ({{pool}})",
          "refId": "A"
        }
      ],
      "title": "Pool checkout wait p99",
      "type": "timeseries"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "tags": ["ruhu", "database", "pool"],
  "templating": {
    "list": [
      {
        "current": {},
        "hide": 0,
        "label": "Datasource",
        "name": "datasource",
        "options": [],
        "query": "prometheus",
        "refresh": 1,
        "type": "datasource"
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Ruhu — Database",
  "uid": "ruhu-database-v1",
  "version": 1
}
