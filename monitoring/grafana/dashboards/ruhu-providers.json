{
  "__inputs": [],
  "annotations": { "list": [] },
  "description": "Ruhu LLM providers — latency, error rate, token spend.",
  "editable": true,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 1,
      "title": "LLM latency",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "s" },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 1 },
      "id": 2,
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(ruhu_llm_request_duration_seconds_bucket[5m])) by (le, provider, model, stage))",
          "legendFormat": "p95 {{provider}}/{{model}} {{stage}}",
          "refId": "A"
        }
      ],
      "title": "LLM p95 latency by provider / model / stage",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "percentunit", "min": 0, "max": 1 },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 1 },
      "id": 3,
      "targets": [
        {
          "expr": "sum(rate(ruhu_provider_error_total[5m])) by (provider, kind) / sum(rate(ruhu_llm_request_duration_seconds_count[5m])) by (provider)",
          "legendFormat": "{{provider}} / {{kind}}",
          "refId": "A"
        }
      ],
      "title": "Provider error rate by kind",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 9 },
      "id": 4,
      "title": "Token throughput",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "short" },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 10 },
      "id": 5,
      "targets": [
        {
          "expr": "sum(rate(ruhu_llm_tokens_total[5m])) by (provider, model, direction)",
          "legendFormat": "{{provider}}/{{model}} {{direction}}",
          "refId": "A"
        }
      ],
      "title": "Token rate/s by provider, model, direction",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "currencyUSD" },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 10 },
      "id": 6,
      "targets": [
        {
          "expr": "sum(rate(ruhu_llm_cost_usd_total[1h])) by (provider, model) * 3600",
          "legendFormat": "{{provider}}/{{model}}",
          "refId": "A"
        }
      ],
      "title": "Estimated LLM spend USD/hr by model",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 18 },
      "id": 7,
      "title": "Cumulative cost",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "unit": "currencyUSD",
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 100 },
            { "color": "red", "value": 500 }
          ]}
        },
        "overrides": []
      },
      "gridPos": { "h": 5, "w": 8, "x": 0, "y": 19 },
      "id": 8,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "background" },
      "targets": [
        {
          "expr": "increase(ruhu_llm_cost_usd_total[24h])",
          "legendFormat": "{{provider}}/{{model}}",
          "refId": "A"
        }
      ],
      "title": "LLM cost last 24h (USD)",
      "type": "stat"
    }
  ],
  "refresh": "1m",
  "schemaVersion": 38,
  "tags": ["ruhu", "providers", "llm", "cost"],
  "templating": {
    "list": [
      {
        "current": {},
        "hide": 0,
        "label": "Datasource",
        "name": "datasource",
        "options": [],
        "query": "prometheus",
        "refresh": 1,
        "type": "datasource"
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Ruhu — Providers",
  "uid": "ruhu-providers-v1",
  "version": 1
}
