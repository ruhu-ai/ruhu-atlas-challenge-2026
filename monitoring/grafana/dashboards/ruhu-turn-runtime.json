{
  "__inputs": [],
  "annotations": { "list": [] },
  "description": "Ruhu turn runtime — turns/sec, tool-call status, error kinds.",
  "editable": true,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 1,
      "title": "Turn throughput",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "reqps" },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 1 },
      "id": 2,
      "targets": [
        {
          "expr": "sum(rate(ruhu_kernel_turns_total[5m])) by (channel, outcome)",
          "legendFormat": "{{channel}} / {{outcome}}",
          "refId": "A"
        }
      ],
      "title": "Turns/s by channel and outcome",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "s" },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 1 },
      "id": 3,
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(ruhu_kernel_turn_duration_seconds_bucket[5m])) by (le, channel))",
          "legendFormat": "p95 {{channel}}",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.50, sum(rate(ruhu_kernel_turn_duration_seconds_bucket[5m])) by (le, channel))",
          "legendFormat": "p50 {{channel}}",
          "refId": "B"
        }
      ],
      "title": "Turn duration p50 / p95 by channel",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 9 },
      "id": 4,
      "title": "Errors",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "reqps" },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 10 },
      "id": 5,
      "targets": [
        {
          "expr": "sum(rate(ruhu_turn_error_total[5m])) by (error_kind)",
          "legendFormat": "{{error_kind}}",
          "refId": "A"
        }
      ],
      "title": "Turn errors/s by kind",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "reqps" },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 10 },
      "id": 6,
      "targets": [
        {
          "expr": "sum(rate(ruhu_tool_invocations_total[5m])) by (executor_kind, status)",
          "legendFormat": "{{executor_kind}} / {{status}}",
          "refId": "A"
        }
      ],
      "title": "Tool invocations/s by executor and status",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 18 },
      "id": 7,
      "title": "Trace persistence",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "s" },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 19 },
      "id": 8,
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum(rate(ruhu_trace_write_latency_seconds_bucket[5m])) by (le))",
          "legendFormat": "p99",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(ruhu_trace_write_latency_seconds_bucket[5m])) by (le))",
          "legendFormat": "p95",
          "refId": "B"
        }
      ],
      "title": "TurnTrace write latency p95 / p99 (SLO: p99 < 50ms)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "reqps" },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 19 },
      "id": 9,
      "targets": [
        {
          "expr": "sum(rate(ruhu_trace_write_failure_total[5m])) by (reason)",
          "legendFormat": "failure / {{reason}}",
          "refId": "A"
        },
        {
          "expr": "sum(rate(ruhu_trace_write_truncations_total[5m]))",
          "legendFormat": "truncations",
          "refId": "B"
        }
      ],
      "title": "Trace write failures + truncations/s",
      "type": "timeseries"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "tags": ["ruhu", "turns", "kernel"],
  "templating": {
    "list": [
      {
        "current": {},
        "hide": 0,
        "label": "Datasource",
        "name": "datasource",
        "options": [],
        "query": "prometheus",
        "refresh": 1,
        "type": "datasource"
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Ruhu — Turn Runtime",
  "uid": "ruhu-turns-v1",
  "version": 1
}
