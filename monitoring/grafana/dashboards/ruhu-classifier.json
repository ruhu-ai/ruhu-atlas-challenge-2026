{
  "__inputs": [],
  "annotations": { "list": [] },
  "description": "Prefill-first classifier — decisions, latency, confidence, prefix-cache savings, errors. See docs/pre-fill-intent-classifier-design/04-runtime-spec.md.",
  "editable": true,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 1,
      "title": "Throughput",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "reqps" },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 1 },
      "id": 2,
      "targets": [
        {
          "expr": "topk(10, sum by (intent_name) (rate(ruhu_classifier_decisions_total{agent_id=~\"$agent_id\"}[5m])))",
          "legendFormat": "{{intent_name}}",
          "refId": "A"
        }
      ],
      "title": "Decisions/s by intent (top 10)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "percentunit" },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 1 },
      "id": 3,
      "targets": [
        {
          "expr": "sum(rate(ruhu_classifier_unknown_total{agent_id=~\"$agent_id\"}[5m])) / clamp_min(sum(rate(ruhu_classifier_unknown_total{agent_id=~\"$agent_id\"}[5m])) + sum(rate(ruhu_classifier_decisions_total{agent_id=~\"$agent_id\"}[5m])), 0.0001)",
          "legendFormat": "unknown rate",
          "refId": "A"
        }
      ],
      "title": "Unknown rate (SLO: < 10%)",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 9 },
      "id": 4,
      "title": "Latency",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "s" },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 10 },
      "id": 5,
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le, backend) (rate(ruhu_classifier_request_duration_seconds_bucket{agent_id=~\"$agent_id\"}[5m])))",
          "legendFormat": "p50 {{backend}}",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le, backend) (rate(ruhu_classifier_request_duration_seconds_bucket{agent_id=~\"$agent_id\"}[5m])))",
          "legendFormat": "p95 {{backend}}",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le, backend) (rate(ruhu_classifier_request_duration_seconds_bucket{agent_id=~\"$agent_id\"}[5m])))",
          "legendFormat": "p99 {{backend}}",
          "refId": "C"
        }
      ],
      "title": "Classifier latency p50 / p95 / p99 by backend (SLO: p95 < 250ms)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "s" },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 10 },
      "id": 6,
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, cache_hit) (rate(ruhu_classifier_request_duration_seconds_bucket{agent_id=~\"$agent_id\"}[5m])))",
          "legendFormat": "p95 cache_hit={{cache_hit}}",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.50, sum by (le, cache_hit) (rate(ruhu_classifier_request_duration_seconds_bucket{agent_id=~\"$agent_id\"}[5m])))",
          "legendFormat": "p50 cache_hit={{cache_hit}}",
          "refId": "B"
        }
      ],
      "title": "Latency by prefix-cache hit (validates prefill-first savings)",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 18 },
      "id": 7,
      "title": "Confidence calibration",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "percentunit", "min": 0, "max": 1 },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 19 },
      "id": 8,
      "targets": [
        {
          "expr": "histogram_quantile(0.10, sum by (le) (rate(ruhu_classifier_confidence_bucket{agent_id=~\"$agent_id\"}[5m])))",
          "legendFormat": "p10",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.50, sum by (le) (rate(ruhu_classifier_confidence_bucket{agent_id=~\"$agent_id\"}[5m])))",
          "legendFormat": "p50",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.90, sum by (le) (rate(ruhu_classifier_confidence_bucket{agent_id=~\"$agent_id\"}[5m])))",
          "legendFormat": "p90",
          "refId": "C"
        }
      ],
      "title": "Confidence p10 / p50 / p90 (low p10 → many borderline decisions)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "scheme", "scheme": "Spectral" }, "unit": "short" },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 19 },
      "id": 9,
      "options": {
        "calculate": false,
        "yAxis": { "decimals": 2, "unit": "percentunit" }
      },
      "targets": [
        {
          "expr": "sum by (le) (rate(ruhu_classifier_confidence_bucket{agent_id=~\"$agent_id\"}[5m]))",
          "format": "heatmap",
          "legendFormat": "{{le}}",
          "refId": "A"
        }
      ],
      "title": "Confidence distribution (heatmap)",
      "type": "heatmap"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 27 },
      "id": 10,
      "title": "Prefix-cache savings",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "short" },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 28 },
      "id": 11,
      "targets": [
        {
          "expr": "sum by (cache_hit) (rate(ruhu_classifier_prefill_tokens_total{agent_id=~\"$agent_id\"}[5m]))",
          "legendFormat": "tokens/s cache_hit={{cache_hit}}",
          "refId": "A"
        }
      ],
      "title": "Prefill tokens/s by cache hit (cache_hit=true should dominate)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "percentunit" },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 28 },
      "id": 12,
      "targets": [
        {
          "expr": "sum(rate(ruhu_classifier_prefill_tokens_total{agent_id=~\"$agent_id\",cache_hit=\"true\"}[5m])) / clamp_min(sum(rate(ruhu_classifier_prefill_tokens_total{agent_id=~\"$agent_id\"}[5m])), 0.0001)",
          "legendFormat": "cache hit ratio",
          "refId": "A"
        }
      ],
      "title": "Prefix-cache hit ratio (target: > 80% in steady state)",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 36 },
      "id": 13,
      "title": "Errors",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "reqps" },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 37 },
      "id": 14,
      "targets": [
        {
          "expr": "sum by (error_kind) (rate(ruhu_classifier_errors_total[5m]))",
          "legendFormat": "{{error_kind}}",
          "refId": "A"
        }
      ],
      "title": "Classifier errors/s by kind",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "reqps" },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 37 },
      "id": 15,
      "targets": [
        {
          "expr": "sum by (backend) (rate(ruhu_classifier_errors_total[5m]))",
          "legendFormat": "errors {{backend}}",
          "refId": "A"
        },
        {
          "expr": "sum by (backend) (rate(ruhu_classifier_decisions_total[5m]) + rate(ruhu_classifier_unknown_total[5m]))",
          "legendFormat": "decisions {{backend}}",
          "refId": "B"
        }
      ],
      "title": "Backend health: errors vs decisions",
      "type": "timeseries"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "tags": ["ruhu", "classifier", "intent", "llm"],
  "templating": {
    "list": [
      {
        "current": {},
        "hide": 0,
        "label": "Datasource",
        "name": "datasource",
        "options": [],
        "query": "prometheus",
        "refresh": 1,
        "type": "datasource"
      },
      {
        "current": { "selected": true, "text": ".*", "value": ".*" },
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "definition": "label_values(ruhu_classifier_decisions_total, agent_id)",
        "hide": 0,
        "includeAll": true,
        "label": "Agent",
        "name": "agent_id",
        "options": [],
        "query": { "query": "label_values(ruhu_classifier_decisions_total, agent_id)" },
        "refresh": 2,
        "regex": "",
        "type": "query"
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Ruhu — Prefill-First Classifier",
  "uid": "ruhu-classifier-v1",
  "version": 1
}
