# Data plane — RDS Postgres (one instance, two databases) + S3 buckets
# (attachments, backups) + Secret Manager containers.
#
# IMPORTANT: secret containers are created EMPTY here. Populate values
# out-of-band with `aws secretsmanager put-secret-value --secret-id <name>
# --secret-string <value>` before the Fargate service tries to start.

# ── RDS subnet group ────────────────────────────────────────────────────────
resource "aws_db_subnet_group" "main" {
  name       = "${local.name}-db"
  subnet_ids = aws_subnet.private[*].id
  tags       = { Name = "${local.name}-db-subnet-group" }
}

# ── Master password (auto-generated, stored in Secrets Manager) ────────────
resource "random_password" "rds_master" {
  length  = 32
  special = true
  # Postgres-friendly special chars only
  override_special = "!#$%&*()-_=+[]{}<>?"
}

resource "aws_secretsmanager_secret" "rds_master" {
  name        = "${local.name}/rds/master_password"
  description = "RDS master user password (auto-generated by Terraform)"
}

resource "aws_secretsmanager_secret_version" "rds_master" {
  secret_id     = aws_secretsmanager_secret.rds_master.id
  secret_string = random_password.rds_master.result
}

# ── RDS instance ───────────────────────────────────────────────────────────
# One Postgres instance, two databases inside (ruhu_runtime + ruhu_auth)
# matching the app's RUHU_DATABASE_URL / RUHU_AUTH_DATABASE_URL split.
# The `runtime` DB is created via `db_name`; `auth` is created by a
# post-apply migration (see `infra/aws/30-compute.tf` migration job).

resource "aws_db_instance" "main" {
  identifier              = "${local.name}-pg"
  engine                  = "postgres"
  engine_version          = var.rds_engine_version
  instance_class          = var.rds_instance_class
  allocated_storage       = var.rds_allocated_storage_gb
  storage_type            = "gp3"
  storage_encrypted       = true
  db_name                 = "ruhu_runtime"
  username                = "ruhu_admin"
  password                = random_password.rds_master.result
  db_subnet_group_name    = aws_db_subnet_group.main.name
  vpc_security_group_ids  = [aws_security_group.rds.id]
  publicly_accessible     = false
  multi_az                = false # single-AZ for pre-seed cost
  backup_retention_period = 7
  skip_final_snapshot     = true # set to false + add final_snapshot_identifier for staging+
  deletion_protection     = var.rds_deletion_protection
  apply_immediately       = true

  tags = { Name = "${local.name}-pg" }
}

# ── Computed DB connection strings, stored as secrets ──────────────────────
# The compute task reads these via env-from-secret refs.

resource "aws_secretsmanager_secret" "db_url_runtime" {
  name        = "${local.name}/RUHU_DATABASE_URL"
  description = "Runtime DB connection string (psycopg async-compatible)"
}

resource "aws_secretsmanager_secret_version" "db_url_runtime" {
  secret_id = aws_secretsmanager_secret.db_url_runtime.id
  secret_string = format(
    "postgresql+psycopg://%s:%s@%s:%d/%s",
    aws_db_instance.main.username,
    random_password.rds_master.result,
    aws_db_instance.main.address,
    aws_db_instance.main.port,
    "ruhu_runtime",
  )
}

resource "aws_secretsmanager_secret" "db_url_auth" {
  name        = "${local.name}/RUHU_AUTH_DATABASE_URL"
  description = "Auth DB connection string"
}

resource "aws_secretsmanager_secret_version" "db_url_auth" {
  secret_id = aws_secretsmanager_secret.db_url_auth.id
  secret_string = format(
    "postgresql+psycopg://%s:%s@%s:%d/%s",
    aws_db_instance.main.username,
    random_password.rds_master.result,
    aws_db_instance.main.address,
    aws_db_instance.main.port,
    "ruhu_auth",
  )
}

# ── App-secret containers (empty; populate out-of-band) ────────────────────
# One Secrets Manager entry per app secret. Created with no version so
# `terraform apply` doesn't fail when there's no real value yet. Ops
# populates each with `aws secretsmanager put-secret-value`.

resource "aws_secretsmanager_secret" "app_secrets" {
  for_each    = toset(var.secret_env_keys)
  name        = "${local.name}/${each.key}"
  description = "App secret consumed by the Fargate task as env-var ${each.key}"
}

# ── S3 buckets ──────────────────────────────────────────────────────────────
# Attachments (call recordings, uploaded files, etc.).

resource "aws_s3_bucket" "attachments" {
  bucket = "${local.name}-attachments"
}

resource "aws_s3_bucket_versioning" "attachments" {
  bucket = aws_s3_bucket.attachments.id
  versioning_configuration { status = "Enabled" }
}

resource "aws_s3_bucket_server_side_encryption_configuration" "attachments" {
  bucket = aws_s3_bucket.attachments.id
  rule {
    apply_server_side_encryption_by_default { sse_algorithm = "AES256" }
  }
}

resource "aws_s3_bucket_public_access_block" "attachments" {
  bucket                  = aws_s3_bucket.attachments.id
  block_public_acls       = true
  block_public_policy     = true
  ignore_public_acls      = true
  restrict_public_buckets = true
}

# Lifecycle: tier old objects to cheaper storage after 90 days
resource "aws_s3_bucket_lifecycle_configuration" "attachments" {
  bucket = aws_s3_bucket.attachments.id

  rule {
    id     = "tier-old-attachments"
    status = "Enabled"
    filter {}

    transition {
      days          = 90
      storage_class = "STANDARD_IA"
    }
    transition {
      days          = 365
      storage_class = "GLACIER"
    }
    noncurrent_version_expiration {
      noncurrent_days = 30
    }
  }
}
