# Keep the build context small. Anything not actually needed at runtime
# should not be copied into the image.

.git
.gitignore
.github
.vscode
.idea

# Python
__pycache__
*.pyc
*.pyo
*.pyd
*.egg-info
.venv
venv
env
.tox
.pytest_cache
.mypy_cache
.ruff_cache
.coverage
htmlcov
dist
build

# Frontend (built separately, deployed to S3/GCS)
frontend
node_modules

# Local dev / fixtures
.env
.env.*
!.env.example
!.env.development.example
local_dev_data
tests
docs
infra
scripts/local
*.md

# Logs / tmp
*.log
*.swp
.DS_Store
