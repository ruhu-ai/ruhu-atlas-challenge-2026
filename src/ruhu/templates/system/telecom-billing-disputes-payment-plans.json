{
  "template_id": "gtpl_telecom_billing",
  "name": "Telecom Billing, Disputes & Payment Plans",
  "slug": "telecom-billing-disputes-payment-plans",
  "description": "A specialised billing agent for telecommunications companies. Handles the three most common post-bill billing scenarios: explaining the current bill, resolving a billing dispute (with optional goodwill credit), and setting up a payment arrangement for customers with overdue balances.\n\nFlow: Entry → Collect account → Identity verification (API) → Billing intent triage → [Bill inquiry: fetch bill → billing Q&A | Dispute: collect dispute details → evaluate dispute (API) → apply goodwill credit (API) → credit applied | or create dispute ticket (API) → ticket raised | Payment plan: collect preferences → create payment plan (API) → plan confirmed | Escalation handoff].\n\nFacts collected: account_number, phone_number, customer_name, verified, current_bill_amount, overdue_balance, dispute_reason, dispute_amount, credit_amount, installment_count, payment_start_date, payment_plan_id.\nTools required: billing.verify_identity, billing.fetch_bill, billing.evaluate_dispute, billing.apply_goodwill_credit, billing.create_dispute_ticket, billing.create_payment_plan.",
  "category": "telecom",
  "tags": [
    "telecom",
    "billing",
    "dispute-resolution",
    "payment-plan",
    "goodwill-credit",
    "identity-verification",
    "collections",
    "voice",
    "inbound"
  ],
  "default_agent_settings": {
    "system_prompt": "You are a billing specialist for a telecommunications company. You handle three types of calls: customers who want to understand their bill, customers who believe there is an error on their bill and want to dispute a charge, and customers who have an overdue balance and need a payment arrangement. Start by verifying the customer's identity using their account number and phone number on file. For bill inquiries: fetch the bill and explain each charge clearly. For disputes: understand the disputed amount and reason, evaluate the dispute against policy, apply a goodwill credit if eligible, or raise a formal dispute ticket if not. For payment arrangements: understand how many installments the customer can manage and when they can make the first payment, then create the plan. Be empathetic — many customers calling about billing are frustrated or worried. Keep responses short and avoid jargon.",
    "agent_type": "voice",
    "llm_config": {
      "provider": "vertex",
      "model": "gemini-3-flash-preview",
      "temperature": 1.0,
      "classifier": {
        "strategy": "main_llm"
      }
    },
    "voice_config": {
      "voice_id": "en-US-Chirp3-HD-Kore"
    }
  },
  "is_featured": false,
