{
  "template_id": "gtpl_ecommerce_returns",
  "name": "E-commerce Returns & Refunds Agent",
  "slug": "ecommerce-returns-refunds",
  "description": "Handles the full returns, exchanges, and refund lifecycle for e-commerce stores. Looks up the order, verifies return eligibility, classifies the return reason, and processes the customer's preferred resolution — exchange, refund, or store credit — via order management integrations.\n\nFlow: Entry → Collect order ID → Order lookup (API) → Return reason classification → Resolution preference (exchange / refund / store credit) → Authorize return (API) → [Exchange: check inventory → process exchange | Refund: process refund | Store credit: apply credit] → Confirmation terminal or escalation handoff.\n\nFacts collected: order_id, customer_email, customer_name, return_reason, return_category, resolution_preference, rma_number, exchange_sku, refund_amount.\nTools required: orders.lookup_order, orders.authorize_return, orders.check_exchange_inventory, orders.process_exchange, orders.process_refund, orders.process_store_credit.\nHandles outside-return-window and order-not-found edge cases gracefully.",
  "category": "e-commerce",
  "tags": [
    "e-commerce",
    "returns",
    "refunds",
    "exchanges",
    "store-credit",
    "rma",
    "order-management",
    "voice",
    "inbound"
  ],
  "default_agent_settings": {
    "system_prompt": "You are a returns and refunds specialist for an e-commerce store. Your goal is to make the returns experience fast and stress-free. Start by looking up the customer's order using their order number. If the order is within the return window, understand why they want to return the item and what resolution they prefer: a full refund, an exchange for a different item, or store credit. Process their preferred resolution using the order management system. If the order is outside the return window or the return is denied, empathise and offer to escalate to a human agent. Be concise — this is a voice conversation.",
    "agent_type": "voice",
    "llm_config": {
      "provider": "vertex",
      "model": "gemini-3-flash-preview",
      "temperature": 1.0,
      "classifier": {
        "strategy": "main_llm"
      }
    },
    "voice_config": {
      "voice_id": "en-US-Chirp3-HD-Kore"
    }
  },
  "is_featured": false,
  "required_tools": [
    {
      "tool_ref": "commerce.authorize_return",
      "display_name": "Authorize return",
      "description": "Posts a return authorization to your commerce backend; receives an RMA number.",
      "category": "commerce",
      "provider_hints": [
        "shopify",
        "woocommerce",
        "magento",
        "custom_http"
      ],
      "setup_url_path": "canvas?view=library&tool_ref=commerce.authorize_return",
      "documentation_url": null,
      "required": true
    },
    {
