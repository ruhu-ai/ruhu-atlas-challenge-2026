{
  "template_id": "gtpl_healthcare_triage",
  "name": "Healthcare Triage & Scheduling Agent",
  "slug": "healthcare-triage-scheduling",
  "description": "A full-service patient-facing voice agent for healthcare providers. Verifies patient identity via two-factor check (member ID + date of birth), triages intent (symptoms, scheduling, prescription refills), and takes action via EHR integrations.\n\nFlow: Entry → Collect member ID → Collect DOB → Identity verification (EHR) → Intent triage → [Symptom assessment → Emergency transfer | Schedule appointment (EHR) | Prescription refill eligibility check + processing (EHR) | General support conversation].\n\nFacts collected: member_id, date_of_birth, patient_name, verified, chief_complaint, preferred_date, preferred_time, appointment_id, prescription_name, pharmacy_id.\nTools required: ehr.verify_patient, ehr.schedule_appointment, ehr.check_refill_eligibility, ehr.process_refill.\nIncludes emergency escalation handoff for urgent symptoms.",
  "category": "healthcare",
  "tags": [
    "healthcare",
    "patient",
    "scheduling",
    "prescription-refills",
    "identity-verification",
    "ehr",
    "triage",
    "voice",
    "inbound"
  ],
  "default_agent_settings": {
    "system_prompt": "You are a compassionate and professional patient support agent for a healthcare provider. You speak over voice, so keep responses short and clear. Always verify the patient's identity before discussing any health information — ask for their member ID and date of birth. Once verified, help them with: scheduling or rescheduling appointments, requesting prescription refills (confirm prescription name and pharmacy), or understanding their symptoms. If a patient describes urgent or emergency symptoms, immediately transfer them to emergency services. Never diagnose conditions or recommend medications beyond relaying what the EHR system approves.",
    "agent_type": "voice",
    "llm_config": {
      "provider": "vertex",
      "model": "gemini-3-flash-preview",
      "temperature": 1.0,
      "classifier": {
        "strategy": "main_llm"
      }
    },
    "voice_config": {
      "voice_id": "en-US-Chirp3-HD-Kore"
    }
  },
  "is_featured": false,
  "required_tools": [
    {
      "tool_ref": "ehr.check_refill_eligibility",
      "display_name": "Refill eligibility check",
      "description": "Checks whether the named prescription is eligible for refill for this patient.",
      "category": "ehr",
      "provider_hints": [
        "epic",
        "cerner",
        "athena",
        "custom_http"
      ],
      "setup_url_path": "canvas?view=library&tool_ref=ehr.check_refill_eligibility",
      "documentation_url": null,
      "required": false
    },
    {
      "tool_ref": "ehr.submit_refill_request",
      "display_name": "Submit refill request",
      "description": "Submits a prescription refill request to the patient's pharmacy via the EHR.",
      "category": "ehr",
      "provider_hints": [
        "epic",
        "cerner",
        "athena",
        "custom_http"
      ],
      "setup_url_path": "canvas?view=library&tool_ref=ehr.submit_refill_request",
      "documentation_url": null,
      "required": false
    },
    {
      "tool_ref": "ehr.verify_patient",
      "display_name": "Patient identity verification",
      "description": "Verifies a member's identity against the EHR using member ID + date of birth.",
      "category": "ehr",
      "provider_hints": [
        "epic",
        "cerner",
        "athena",
        "custom_http"
      ],
      "setup_url_path": "canvas?view=library&tool_ref=ehr.verify_patient",
      "documentation_url": null,
      "required": true
    },
    {
      "tool_ref": "scheduling.book_appointment",
      "display_name": "Appointment booking",
      "description": "Books an appointment at the requested date/time slot for the verified patient.",
      "category": "scheduling",
